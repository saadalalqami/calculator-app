<CalculatorLayout>:
    orientation: 'vertical'
    
    # شريط التاريخ
    BoxLayout:
        size_hint_y: 0.15
        canvas.before:
            Color:
                rgb: 0.1, 0.1, 0.1
            Rectangle:
                size: self.size
                pos: self.pos
                
        Label:
            text: 'السجل'
            color: 0.5, 0.5, 0.5, 1
            size_hint_x: 0.2
            
        RecycleView:
            size_hint_x: 0.6
            viewclass: 'Label'
            data: [{'text': str(item)} for item in root.history_list]
            RecycleBoxLayout:
                default_size: None, dp(30)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
                
        Button:
            text: 'مسح'
            size_hint_x: 0.2
            on_press: root.clear_history()
            
    # شاشة العرض
    BoxLayout:
        size_hint_y: 0.2
        canvas.before:
            Color:
                rgb: 0.05, 0.05, 0.05
            Rectangle:
                size: self.size
                pos: self.pos
                
        Label:
            text: root.display_text
            font_size: '40sp'
            color: 0.8, 0.8, 0.8, 1
            size_hint_y: 1
            text_size: self.width, None
            halign: 'right'
            valign: 'center'
            
    # أزرار العمليات العلمية
    GridLayout:
        size_hint_y: 0.1
        cols: 5
        spacing: 2
        padding: 2
        
        Button:
            text: 'sin'
            background_color: 0.3, 0.4, 0.6, 1
            on_press: root.scientific_function('sin')
        Button:
            text: 'cos'
            background_color: 0.3, 0.4, 0.6, 1
            on_press: root.scientific_function('cos')
        Button:
            text: 'tan'
            background_color: 0.3, 0.4, 0.6, 1
            on_press: root.scientific_function('tan')
        Button:
            text: '√'
            background_color: 0.3, 0.4, 0.6, 1
            on_press: root.scientific_function('√')
        Button:
            text: 'log'
            background_color: 0.3, 0.4, 0.6, 1
            on_press: root.scientific_function('log')
            
    # أزرار العمليات الأساسية
    GridLayout:
        size_hint_y: 0.55
        cols: 4
        spacing: 2
        padding: 2
        
        Button:
            text: 'C'
            background_color: 0.8, 0.3, 0.3, 1
            on_press: root.on_button_press('C')
        Button:
            text: '⌫'
            background_color: 0.8, 0.5, 0.2, 1
            on_press: root.on_button_press('⌫')
        Button:
            text: '%'
            on_press: root.on_button_press('%')
        Button:
            text: '÷'
            on_press: root.on_button_press('÷')
            
        Button:
            text: '7'
            on_press: root.on_button_press('7')
        Button:
            text: '8'
            on_press: root.on_button_press('8')
        Button:
            text: '9'
            on_press: root.on_button_press('9')
        Button:
            text: '×'
            on_press: root.on_button_press('×')
            
        Button:
            text: '4'
            on_press: root.on_button_press('4')
        Button:
            text: '5'
            on_press: root.on_button_press('5')
        Button:
            text: '6'
            on_press: root.on_button_press('6')
        Button:
            text: '-'
            on_press: root.on_button_press('-')
            
        Button:
            text: '1'
            on_press: root.on_button_press('1')
        Button:
            text: '2'
            on_press: root.on_button_press('2')
        Button:
            text: '3'
            on_press: root.on_button_press('3')
        Button:
            text: '+'
            on_press: root.on_button_press('+')
            
        Button:
            text: '0'
            on_press: root.on_button_press('0')
        Button:
            text: '.'
            on_press: root.on_button_press('.')
        Button:
            text: '='
            background_color: 0.2, 0.6, 0.3, 1
            on_press: root.on_button_press('=')
